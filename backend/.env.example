# ============================================
# 金融多智能体协作系统 - 环境配置
# ============================================

# --- LLM 配置 ---
# Qwen2.5-14B 本地部署（主推理模型）
LLM_API_KEY=your_api_key_here
QWEN_API_BASE=http://localhost:11434/v1
QWEN_MODEL_NAME=qwen2.5:14b

# DeepSeek-V3（脱敏后的逻辑结构校验）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat

# --- 数据库配置 ---
# Milvus 向量数据库（历史研报与路演纪要切片）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=financial_docs

# MySQL 业务数据库
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=financial_agent

# Redis（异步任务队列与状态缓存）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Wind 金融终端配置 ---
WIND_API_ENDPOINT=https://api.wind.com.cn
WIND_API_KEY=your_wind_api_key_here

# --- 应用配置 ---
APP_ENV=development
LOG_LEVEL=DEBUG
MAX_RETRY_ROUNDS=3
