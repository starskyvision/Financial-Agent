# ============================================
# 金融多智能体协作系统 - 环境配置
# ============================================

# --- LLM 配置 ---
# 主模型（必填）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 按 Agent 覆盖模型（可选，默认用上面的主模型）
# LLM_MODEL=deepseek-chat
# LLM_MODEL_INTENT=deepseek-chat
# LLM_MODEL_FINANCIAL=deepseek-chat
# LLM_MODEL_SENTIMENT=deepseek-chat
# LLM_MODEL_REVIEWER=deepseek-chat

# LLM 调用参数
# LLM_MAX_RETRIES=3
# LLM_RATE_LIMIT=30
# LLM_CB_THRESHOLD=3
# LLM_CB_RECOVERY=30
# LLM_RETRY_BACKOFF_BASE=2

# 备选降级（可选）
# QWEN_API_KEY=
# QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-turbo

# --- 数据库配置 ---
DATABASE_URL=postgresql://user:password@localhost:5432/financial_agent
PG_PASSWORD=your_db_password_here

# Redis
REDIS_URL=redis://localhost:6379/0

# --- 熔断器 ---
# CB_FAILURE_THRESHOLD=5
# CB_RECOVERY_TIMEOUT=30.0

# --- 数据源 ---
DATA_SOURCE=akshare
# FETCH_TIMEOUT=30
# NEWS_LOOKBACK_DAYS=30
# DOC_FETCH_LIMIT=5
# AKSHARE_CB_THRESHOLD=3
# AKSHARE_CB_RECOVERY=60

# --- 异常检测 ---
# ANOMALY_WARNING_THRESHOLD=0.30
# ANOMALY_CRITICAL_THRESHOLD=0.50
# FACT_CHECK_TOLERANCE=0.01

# --- RAG / Embedding ---
# BGE_M3_PATH=./models/bge-m3
# EMBEDDING_DIM=1024
# EMBEDDER_DEVICE=cpu
# RAG_CHUNK_SIZE=500
# RAG_CHUNK_OVERLAP=50
# RAG_TOP_K=5

# --- 异步任务 ---
# TASK_TTL=3600
# CELERY_MAX_RETRIES=2
# CELERY_RETRY_COUNTDOWN=10
# MAX_RETRY_ROUNDS=3

# --- 前端 ---
FRONTEND_URL=http://localhost:5173
# CORS_ORIGINS=http://localhost:5173

# --- 认证 ---
# API_KEY=your_api_key_here
# IP_WHITELIST=127.0.0.1,::1
# RATE_LIMIT=60

# --- 应用配置 ---
APP_ENV=development
LOG_LEVEL=DEBUG
# APP_VERSION=1.0.0
