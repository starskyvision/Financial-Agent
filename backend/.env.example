# ============================================
# 金融多智能体协作系统 - 环境配置
# ============================================

# --- LLM 配置 ---
# 主模型（必填）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 按 Agent 覆盖模型（可选，默认用上面的主模型）
# LLM_MODEL=deepseek-chat
# LLM_MODEL_INTENT=deepseek-chat
# LLM_MODEL_FINANCIAL=deepseek-chat
# LLM_MODEL_SENTIMENT=deepseek-chat
# LLM_MODEL_REVIEWER=deepseek-chat

# 备选降级（可选）
# QWEN_API_KEY=
# QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-turbo

# --- 数据库配置 ---
MILVUS_HOST=localhost
MILVUS_PORT=19530

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=financial_agent_2024
MYSQL_DATABASE=financial_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# --- 数据源 ---
DATA_SOURCE=akshare

# --- 前端 ---
FRONTEND_URL=http://localhost:5173

# --- 应用配置 ---
APP_ENV=development
LOG_LEVEL=DEBUG
